{
  "name": "shallavar-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "dev:turbo": "NODE_OPTIONS='--max-old-space-size=4096' next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "clean": "rm -rf .next node_modules/.cache",
    "monitor:start": "chmod +x monitor-and-recover.sh && ./monitor-and-recover.sh",
    "monitor:stop": "pkill -f 'monitor-and-recover.sh' 2>/dev/null && echo 'Monitor stopped'",
    "monitor:logs": "tail -50 .memory-monitor.log 2>/dev/null || echo 'No monitor logs yet'"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "5.9.3"
  }
}
